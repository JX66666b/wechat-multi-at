<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 标题区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="海鸥 Multi-@"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0.0"
                android:textSize="12sp"
                android:textColor="#666666" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="微信群聊 @ 多选增强工具"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="无需Root，无需Xposed，通过无障碍服务实现"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginBottom="24dp" />

        <!-- 步骤1: 无障碍服务 -->
        <LinearLayout
            android:id="@+id/card_accessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/card_bg"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:background="@drawable/circle_step_bg" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="开启无障碍服务"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginStart="12dp" />

                <TextView
                    android:id="@+id/tv_accessibility_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="未开启"
                    android:textSize="13sp"
                    android:textColor="#FF0000" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="进入 设置 → 无障碍 → 已安装的服务 → 海鸥 Multi-@ → 开启"
                android:textSize="12sp"
                android:textColor="#666666"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_open_accessibility"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="去开启无障碍服务"
                android:textAllCaps="false"
                android:backgroundTint="#2196F3" />

        </LinearLayout>

        <!-- 步骤2: 悬浮窗权限 -->
        <LinearLayout
            android:id="@+id/card_overlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/card_bg"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="2"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:background="@drawable/circle_step_bg" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="悬浮窗权限"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginStart="12dp" />

                <TextView
                    android:id="@+id/tv_overlay_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="未授权"
                    android:textSize="13sp"
                    android:textColor="#FF0000" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="用于显示浮动控制按钮（用来开关多选模式）"
                android:textSize="12sp"
                android:textColor="#666666"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_open_overlay"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="授予悬浮窗权限"
                android:textAllCaps="false"
                android:backgroundTint="#2196F3" />

        </LinearLayout>

        <!-- 使用说明 -->
        <LinearLayout
            android:id="@+id/card_usage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/card_bg"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="使用说明"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. 确保以上两步都已开启\n2. 打开微信群聊\n3. 点击悬浮球上的海鸥图标\n4. 输入@选择第一个人\n5. 之后会自动触发下一个@，继续选人\n6. 选完后再次点击海鸥停止\n7. 发送消息"
                android:textSize="14sp"
                android:textColor="#666666"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

        <!-- 打开微信按钮 -->
        <Button
            android:id="@+id/btn_open_wechat"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="打开微信"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:backgroundTint="#07C160"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp" />

        <!-- 开源信息 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="开源项目 · 海鸥出品"
            android:textSize="12sp"
            android:textColor="#999999"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:onClick="openGitHub" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="有问题？提 Issue ->"
            android:textSize="12sp"
            android:textColor="#1976D2"
            android:gravity="center"
            android:layout_marginBottom="32dp"
            android:onClick="openGitHub" />

    </LinearLayout>
</ScrollView>
