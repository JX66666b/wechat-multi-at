<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 标题 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="海鸥 Multi-@"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0"
                android:textSize="12sp"
                android:textColor="#999" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="微信群聊 @ 多选增强 · 自动搜索续接"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="16dp" />

        <!-- 状态 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/card_bg"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="检查中..."
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="开启后状态栏会有通知图标，点击通知可开关"
                android:textSize="12sp"
                android:textColor="#999" />
        </LinearLayout>

        <!-- 激活方式 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选择一种激活方式："
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="12dp" />

        <!-- 方式1: 无障碍 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/card_bg"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:background="@drawable/circle_step_bg" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="无障碍服务"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp"
                    android:textColor="#1A1A1A" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="最简单的方式，无需电脑。进入设置开启即可"
                android:textSize="13sp"
                android:textColor="#666"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_open_settings"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="去开启无障碍服务"
                android:textAllCaps="false"
                android:backgroundTint="#2196F3" />
        </LinearLayout>

        <!-- 方式2: ADB命令 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/card_bg"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="2"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:background="@drawable/circle_step_bg" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ADB 命令"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp"
                    android:textColor="#1A1A1A" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="电脑连接手机USB调试后执行，无需手动翻设置"
                android:textSize="13sp"
                android:textColor="#666"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_adb_command"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:background="#F5F5F5"
                android:text="adb shell ..."
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textColor="#333"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_copy_adb"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="复制 ADB 命令"
                android:textAllCaps="false"
                android:backgroundTint="#FF9800" />
        </LinearLayout>

        <!-- 方式3: Shizuku -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/card_bg"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="3"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:background="@drawable/circle_step_bg" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Shizuku"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp"
                    android:textColor="#1A1A1A" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="通过Shizuku授权，在手机上直接激活（需装Shizuku App）"
                android:textSize="13sp"
                android:textColor="#666"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_shizuku"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="通过 Shizuku 激活"
                android:textAllCaps="false"
                android:backgroundTint="#9C27B0" />
        </LinearLayout>

        <!-- 打开微信 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/card_bg"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="使用说明"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. 开启服务后打开微信群聊\n2. 输入 @ + 关键词 搜索联系人\n3. 选完一个人 → 自动续接 @ + 关键词\n4. 继续选下一个人...\n5. 选完了下拉通知栏点「关闭」\n\n提示：通知栏会显示 🟢/🔴 状态"
                android:textSize="13sp"
                android:textColor="#666"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_open_wechat"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="打开微信"
                android:textAllCaps="false"
                android:backgroundTint="#07C160" />
        </LinearLayout>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="开源项目 · 海鸥出品"
            android:textSize="12sp"
            android:textColor="#999"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"
            android:onClick="openGitHub" />

    </LinearLayout>
</ScrollView>
