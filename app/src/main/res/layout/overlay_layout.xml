<?xml version="1.0" encoding="utf-8"?>
<!-- 海鸥悬浮球布局 -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="56dp"
    android:layout_height="56dp"
    android:clickable="true"
    android:focusable="true">

    <!-- 背景圆 -->
    <View
        android:id="@+id/active_indicator"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="center"
        android:background="@drawable/circle_overlay_active"
        android:visibility="gone" />

    <!-- 主圆 -->
    <View
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="center"
        android:background="@drawable/circle_overlay_bg" />

    <!-- 海鸥图标 -->
    <ImageView
        android:id="@+id/seagull_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_seagull"
        android:contentDescription="海鸥Multi-@"
        android:alpha="0.7" />

    <!-- @数量角标 -->
    <TextView
        android:id="@+id/at_count_badge"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_gravity="top|end"
        android:gravity="center"
        android:text="0"
        android:textSize="10sp"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:background="@drawable/circle_badge"
        android:visibility="gone" />

</FrameLayout>
